# --- Postgres ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=memory
POSTGRES_USER=memory
POSTGRES_PASSWORD=CHANGE_ME

# --- Embeddings ---
EMBED_PROVIDER=ollama
OLLAMA_URL=http://ollama:11434
EMBED_MODEL=nomic-embed-text
EMBED_DIMS=768

# --- Repos ---
REPOS_ROOT=/repos
STANDARDS_REPO=enterprise-standards
DEFAULT_STANDARDS_VERSION=local

# --- Gateway ---
GATEWAY_MAX_BUNDLE_CHARS=40000
GATEWAY_DEFAULT_K=12
BUNDLE_CACHE_TTL_SECONDS=300

# --- Inter-Service Auth ---
INTERNAL_SERVICE_TOKEN=CHANGE_ME

# --- GitHub Provider ---
# To enable the GitHub provider, set GITHUB_TOKEN to a fine-grained PAT
# with Contents: Read-only and Metadata: Read-only permissions.
# NEVER commit your PAT to version control.
# GITHUB_TOKEN=ghp_your_token_here
# GITHUB_REPOS=owner/repo1,owner/repo2
# GITHUB_API_URL=https://api.github.com
# GITHUB_DEFAULT_BRANCH=main

# --- Multi-Tenancy ---
DEFAULT_NAMESPACE=default
